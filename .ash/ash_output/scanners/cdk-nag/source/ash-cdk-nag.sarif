0-17","Statement":[{"Effect":"Allow","Action":["secretsmanager:GetSecretValue","secretsmanager:UpdateSecret","rds:DescribeDBClusters"],"Resource":"*","Condition":{"StringEquals":{"aws:ResourceAccount":{"Fn::Sub":"${AWS::AccountId}"}}}},{"Effect":"Allow","Action":["ec2:DescribeNetworkInterfaces","ec2:CreateNetworkInterface","ec2:DeleteNetworkInterface","ec2:DescribeInstances","ec2:AttachNetworkInterface"],"Resource":"*","Condition":{"StringEquals":{"aws:ResourceAccount":{"Fn::Sub":"${AWS::AccountId}"}}}},{"Effect":"Allow","Action":["s3:PutObject"],"Resource":"arn:aws:s3:::cloudformation-custom-resource-response-useast1/*"}]}}]}}}}}},{"ruleId":"AwsSolutions-L1","kind":"review","level":"none","message":{"text":"The non-container Lambda function is not configured to use the latest runtime version.\n\nException Reason: The non-container Lambda function is not configured to use the latest runtime version. Keeping this for compatibility reasons"},"analysisTarget":{"uri":"deployment/database/aurora/aurora-global-primary-cluster.yml"},"locations":[{"id":1,"physicalLocation":{"artifactLocation":{"uri":"deployment/database/aurora/aurora-global-primary-cluster.yml"},"region":{"startLine":336,"startColumn":2,"endLine":336,"endColumn":22,"snippet":{"text":"Resources:\n  UpdateSecretFunction:\n    Metadata:\n      cdk_nag:\n        rules_to_suppress:\n          - id: AwsSolutions-L1\n            reason: The non-container Lambda function is not configured to use the latest runtime version. Keeping this for\n              compatibility reasons\n    Properties:\n      Code:\n        ZipFile: \"import json\\nimport boto3\\nimport os\\nimport logging\\nimport cfnresponse\\nlogging.basicConfig(level=logging.INFO,\\\n          \\ format='%(asctime)s - %(name)s - %(levelname)s - %(message)s')\\ndef handler(event, context):\\n  try:\\n    responseData\\\n          \\ = {}\\n    if event.get('RequestType') == 'Create':\\n      secretsmanager_client = boto3.client('secretsmanager')\\n\\\n          \\      rds_client = boto3.client('rds')\\n\\n      secret_name = os.environ['SecretName']\\n      db_cluster_identifier\\\n          \\ = os.environ['DBClusterIdentifier']\\n\\n      # Describe the DB cluster to get the endpoint and other details\\n\\\n          \\      db_cluster_info = rds_client.describe_db_clusters(DBClusterIdentifier=db_cluster_identifier)['DBClusters'][0]\\n\\\n          \\      host = db_cluster_info['Endpoint']\\n      port = db_cluster_info['Port']\\n\\n      # Get the current secret\\\n          \\ value\\n      current_secret_value = secretsmanager_client.get_secret_value(SecretId=secret_name)['SecretString']\\n\\\n          \\      current_secret_json = json.loads(current_secret_value)\\n\\n      # Update the secret with additional details\\n\\\n          \\      updated_secret_json = {\\n          \\\"engine\\\": \\\"mysql\\\",\\n          \\\"host\\\": host,\\n          \\\"username\\\"\\\n          : current_secret_json['username'],\\n          \\\"password\\\": current_secret_json['password'],\\n          \\\"dbname\\\"\\\n          : os.environ['DB_NAME'],\\n          \\\"port\\\": port\\n      }\\n\\n      responseData['secrets_manager_response'] =\\\n          \\ secretsmanager_client.update_secret(\\n          SecretId=secret_name,\\n          SecretString=json.dumps(updated_secret_json)\\n\\\n          \\      )\\n\\n      logging.info('Sending %s to cloudformation', responseData['secrets_manager_response'])\\n     \\\n          \\ cfnresponse.send(event, context, cfnresponse.SUCCESS, responseData)\\n    else:\\n      logging.error('Unsupported\\\n          \\ operation: %s', event.get('RequestType'))\\n      responseData['message'] = \\\"Invalid operation\\\"\\n      cfnresponse.send(event,\\\n          \\ context, cfnresponse.SUCCESS, responseData)\\n  except Exception as err:\\n    responseData = {}\\n    responseData['message']\\\n          \\ = 'Failed'\\n    logging.error(err)\\n    cfnresponse.send(event, context, cfnresponse.FAILED, responseData)\\n\"\n      Environment:\n        Variables:\n          DBClusterIdentifier:\n            Ref: DBCluster\n          DB_NAME:\n            Ref: DatabaseName\n          SecretName:\n            Ref: DBCredentialsSecret\n      Handler: index.handler\n      Role:\n        Fn::GetAtt:\n          - LambdaExecutionRole\n          - Arn\n      Runtime: python3.13\n      Timeout: 300\n      VpcConfig:\n        SecurityGroupIds:\n          - Ref: LambdaSecurityGroup\n        SubnetIds:\n          - Fn::Sub: '{{resolve:ssm:Subnet1${Env}}}'\n          - Fn::Sub: '{{resolve:ssm:Subnet2${Env}}}'\n          - Fn::Sub: '{{resolve:ssm:Subnet3${Env}}}'\n    Type: AWS::Lambda::Function\n"}}}}],"properties":{"tags":["aws","cdk","cdk-nag","AwsSolutions","AwsSolutions-L1","UpdateSecretFunction","AWS::Lambda::Function","tool_name::cdk-nag","tool_type::IAC"],"cdk_nag_finding":{"rule_id":"AwsSolutions-L1","resource_id":"ASHCDKNagScanner/deployment--database--aurora--aurora-global-primary-cluster.yml/UpdateSecretFunction","compliance":"Suppressed","exception_reason":"The non-container Lambda function is not configured to use the latest runtime version. Keeping this for compatibility reasons","rule_level":"Error","rule_info":"The non-container Lambda function is not configured to use the latest runtime version."},"cfn_resource":{"Resources":{"UpdateSecretFunction":{"Type":"AWS::Lambda::Function","Metadata":{"cdk_nag":{"rules_to_suppress":[{"id":"AwsSolutions-L1","reason":"The non-container Lambda function is not configured to use the latest runtime version. Keeping this for compatibility reasons"}]}},"Properties":{"Handler":"index.handler","Role":{"Fn::GetAtt":["LambdaExecutionRole","Arn"]},"Code":{"ZipFile":"import json\nimport boto3\nimport os\nimport logging\nimport cfnresponse\nlogging.basicConfig(level=logging.INFO, format='%(asctime)s - %(name)s - %(levelname)s - %(message)s')\ndef handler(event, context):\n  try:\n    responseData = {}\n    if event.get('RequestType') == 'Create':\n      secretsmanager_client = boto3.client('secretsmanager')\n      rds_client = boto3.client('rds')\n\n      secret_name = os.environ['SecretName']\n      db_cluster_identifier = os.environ['DBClusterIdentifier']\n\n      # Describe the DB cluster to get the endpoint and other details\n      db_cluster_info = rds_client.describe_db_clusters(DBClusterIdentifier=db_cluster_identifier)['DBClusters'][0]\n      host = db_cluster_info['Endpoint']\n      port = db_cluster_info['Port']\n\n      # Get the current secret value\n      current_secret_value = secretsmanager_client.get_secret_value(SecretId=secret_name)['SecretString']\n      current_secret_json = json.loads(current_secret_value)\n\n      # Update the secret with additional details\n      updated_secret_json = {\n          \"engine\": \"mysql\",\n          \"host\": host,\n          \"username\": current_secret_json['username'],\n          \"password\": current_secret_json['password'],\n          \"dbname\": os.environ['DB_NAME'],\n          \"port\": port\n      }\n\n      responseData['secrets_manager_response'] = secretsmanager_client.update_secret(\n          SecretId=secret_name,\n          SecretString=json.dumps(updated_secret_json)\n      )\n\n      logging.info('Sending %s to cloudformation', responseData['secrets_manager_response'])\n      cfnresponse.send(event, context, cfnresponse.SUCCESS, responseData)\n    else:\n      logging.error('Unsupported operation: %s', event.get('RequestType'))\n      responseData['message'] = \"Invalid operation\"\n      cfnresponse.send(event, context, cfnresponse.SUCCESS, responseData)\n  except Exception as err:\n    responseData = {}\n    responseData['message'] = 'Failed'\n    logging.error(err)\n    cfnresponse.send(event, context, cfnresponse.FAILED, responseData)\n"},"Environment":{"Variables":{"DB_NAME":{"Ref":"DatabaseName"},"SecretName":{"Ref":"DBCredentialsSecret"},"DBClusterIdentifier":{"Ref":"DBCluster"}}},"Runtime":"python3.13","Timeout":300,"VpcConfig":{"SubnetIds":[{"Fn::Sub":"{{resolve:ssm:Subnet1${Env}}}"},{"Fn::Sub":"{{resolve:ssm:Subnet2${Env}}}"},{"Fn::Sub":"{{resolve:ssm:Subnet3${Env}}}"}],"SecurityGroupIds":[{"Ref":"LambdaSecurityGroup"}]}}}}}}},{"ruleId":"AwsSolutions-EC23","kind":"informational","level":"none","message":{"text":"The Security Group allows for 0.0.0.0/0 or ::/0 inbound access.\n\nException Reason: N/A"},"analysisTarget":{"uri":"deployment/database/aurora/aurora-global-primary-cluster.yml"},"locations":[{"id":1,"physicalLocation":{"artifactLocation":{"uri":"deployment/database/aurora/aurora-global-primary-cluster.yml"},"region":{"startLine":481,"startColumn":2,"endLine":481,"endColumn":47,"snippet":{"text":"Resources:\n  VPCEndpointSecretsManagerSecurityGroupIngress:\n    Properties:\n      FromPort: 443\n      GroupId:\n        Fn::Sub: '{{resolve:ssm:VPCEndpointSecretsManagerSGId${Env}}}'\n      IpProtocol: tcp\n      SourceSecurityGroupId:\n        Ref: LambdaSecurityGroup\n      ToPort: 443\n    Type: AWS::EC2::SecurityGroupIngress\n"}}}}],"properties":{"tags":["aws","cdk","cdk-nag","AwsSolutions","AwsSolutions-EC23","VPCEndpointSecretsManagerSecurityGroupIngress","AWS::EC2::SecurityGroupIngress","tool_name::cdk-nag","tool_type::IAC"],"cdk_nag_finding":{"rule_id":"AwsSolutions-EC23","resource_id":"ASHCDKNagScanner/deployment--database--aurora--aurora-global-primary-cluster.yml/VPCEndpointSecretsManagerSecurityGroupIngress","compliance":"Compliant","exception_reason":"N/A","rule_level":"Error","rule_info":"The Security Group allows for 0.0.0.0/0 or ::/0 inbound access."},"cfn_resource":{"Resources":{"VPCEndpointSecretsManagerSecurityGroupIngress":{"Type":"AWS::EC2::SecurityGroupIngress","Properties":{"GroupId":{"Fn::Sub":"{{resolve:ssm:VPCEndpointSecretsManagerSGId${Env}}}"},"IpProtocol":"tcp","FromPort":443,"ToPort":443,"SourceSecurityGroupId":{"Ref":"LambdaSecurityGroup"}}}}}}},{"ruleId":"AwsSolutions-EC23","kind":"informational","level":"none","message":{
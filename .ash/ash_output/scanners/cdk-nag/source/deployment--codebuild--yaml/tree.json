\"true\" ]; then\n          echo Logging in to Amazon ECR in $STANDBY_REGION...\n          aws ecr get-login-password --region $STANDBY_REGION | docker login --username AWS --password-stdin $AWS_ACCOUNT_ID.dkr.ecr.$STANDBY_REGION.amazonaws.com\n        fi\n      - PRIMARY_REPO=$AWS_ACCOUNT_ID.dkr.ecr.$PRIMARY_REGION.amazonaws.com/${SERVICE_NAME}${ENV_SUFFIX}\n      - STANDBY_REPO=$AWS_ACCOUNT_ID.dkr.ecr.$STANDBY_REGION.amazonaws.com/${SERVICE_NAME}${ENV_SUFFIX}\n  build:\n    commands:\n      - |\n        echo \"Rewriting Dockerfile to use ECR Public Gallery mirrors...\"\n        sed -i 's#FROM golang:#FROM public.ecr.aws/docker/library/golang:#g' Dockerfile\n        sed -i 's#FROM node:#FROM public.ecr.aws/docker/library/node:#g' Dockerfile\n        sed -i 's#FROM amazoncorretto:#FROM public.ecr.aws/docker/library/amazoncorretto:#g' Dockerfile\n        cat Dockerfile\n      - echo Building Docker image for $SERVICE_NAME...\n      - docker build --platform linux/amd64 -t ${SERVICE_NAME}${ENV_SUFFIX}:${TAG} .\n  post_build:\n    commands:\n      - echo Pushing image to ECR in $PRIMARY_REGION...\n      - docker tag ${SERVICE_NAME}${ENV_SUFFIX}:${TAG} $PRIMARY_REPO:$TAG\n      - docker push $PRIMARY_REPO:$TAG\n      - |\n        if [ \"$PRIMARY_ONLY\" != \"true\" ]; then\n          echo Pushing image to ECR in $STANDBY_REGION...\n          docker tag ${SERVICE_NAME}${ENV_SUFFIX}:${TAG} $STANDBY_REPO:$TAG\n          docker push $STANDBY_REPO:$TAG\n        fi\n      - echo Build and push completed successfully\n","location":{"Fn::Sub":"{{resolve:ssm:canaryBucketName${Env}}}/codebuild/source.zip"},"type":"S3"},"timeoutInMinutes":30}}},"CodeBuildProjectNameParam":{"id":"CodeBuildProjectNameParam","path":"ASHCDKNagScanner/deployment--codebuild.yaml/CodeBuildProjectNameParam","constructInfo":{"fqn":"aws-cdk-lib.aws_ssm.CfnParameter","version":"2.240.0"},"attributes":{"aws:cdk:cloudformation:type":"AWS::SSM::Parameter","aws:cdk:cloudformation:props":{"name":{"Fn::Sub":"codebu
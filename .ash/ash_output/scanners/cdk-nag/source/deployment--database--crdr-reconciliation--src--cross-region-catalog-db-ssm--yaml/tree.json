{"version":"tree-0.1","tree":{"id":"App","path":"","constructInfo":{"fqn":"aws-cdk-lib.App","version":"2.240.0"},"children":{"ASHCDKNagScanner":{"id":"ASHCDKNagScanner","path":"ASHCDKNagScanner","constructInfo":{"fqn":"aws-cdk-lib.Stack","version":"2.240.0"},"children":{"deployment--database--crdr-reconciliation--src--cross-region-catalog-db-ssm.yaml":{"id":"deployment--database--crdr-reconciliation--src--cross-region-catalog-db-ssm.yaml","path":"ASHCDKNagScanner/deployment--database--crdr-reconciliation--src--cross-region-catalog-db-ssm.yaml","constructInfo":{"fqn":"aws-cdk-lib.cloudformation_include.CfnInclude","version":"2.240.0"},"children":{"$Mappings":{"id":"$Mappings","path":"ASHCDKNagScanner/deployment--database--crdr-reconciliation--src--cross-region-catalog-db-ssm.yaml/$Mappings","constructInfo":{"fqn":"constructs.Construct","version":"10.5.1"}},"Env":{"id":"Env","path":"ASHCDKNagScanner/deployment--database--crdr-reconciliation--src--cross-region-catalog-db-ssm.yaml/Env","constructInfo":{"fqn":"aws-cdk-lib.CfnParameter","version":"2.240.0"}},"SourceRegion":{"id":"SourceRegion","path":"ASHCDKNagScanner/deployment--database--crdr-reconciliation--src--cross-region-catalog-db-ssm.yaml/SourceRegion","constructInfo":{"fqn":"aws-cdk-lib.CfnParameter","version":"2.240.0"}},"TargetRegion":{"id":"TargetRegion","path":"ASHCDKNagScanner/deployment--database--crdr-reconciliation--src--cross-region-catalog-db-ssm.yaml/TargetRegion","constructInfo":{"fqn":"aws-cdk-lib.CfnParameter","version":"2.240.0"}},"GlobalClusterIdentifier":{"id":"GlobalClusterIdentifier","path":"ASHCDKNagScanner/deployment--database--crdr-reconciliation--src--cross-region-catalog-db-ssm.yaml/GlobalClusterIdentifier","constructInfo":{"fqn":"aws-cdk-lib.CfnParameter","version":"2.240.0"}},"$Conditions":{"id":"$Conditions","path":"ASHCDKNagScanner/deployment--database--crdr-reconciliation--src--cross-region-catalog-db-ssm.yaml/$Conditions","constructInfo":{"fqn":"constructs.Construct","version":"10.5.1"}},"$Rules":{"id":"$Rules","path":"ASHCDKNagScanner/deployment--database--crdr-reconciliation--src--cross-region-catalog-db-ssm.yaml/$Rules","constructInfo":{"fqn":"constructs.Construct","version":"10.5.1"}},"CrossRegionSnapshotCopySSMAutomation":{"id":"CrossRegionSnapshotCopySSMAutomation","path":"ASHCDKNagScanner/deployment--database--crdr-reconciliation--src--cross-region-catalog-db-ssm.yaml/CrossRegionSnapshotCopySSMAutomation","constructInfo":{"fqn":"aws-cdk-lib.aws_ssm.CfnDocument","version":"2.240.0"},"attributes":{"aws:cdk:cloudformation:type":"AWS::SSM::Document","aws:cdk:cloudformation:props":{"content":{"description":"Aurora RDS Cluster Snapshot and Copy Automation Document","parameters":{"SourceDBsnapshotArn":{"type":"String","description":"(Required) Arn of the cross region DR snapshot","default":""}},"schemaVersion":"0.3","assumeRole":{"Fn::Sub":"{{resolve:secretsmanager:mr-app/CRDRSSMAutomationRoleArn${Env}}}"},"mainSteps":[{"name":"CopyFailoverSnapshot","action":"aws:executeScript","inputs":{"Runtime":"python3.11","Handler":"script_handler","InputPayload":{"SourceDBsnapshotArn":{"Fn::Sub":"{{SourceDBsnapshotArn}}"},"automationid":"{{automation:EXECUTION_ID}}","sourceregion":{"Ref":"SourceRegion"},"targetregion":{"Ref":"TargetRegion"},"kmstargetkey":{"Fn::Sub":"{{resolve:secretsmanager:mr-app/catalog-${TargetRegion}-${GlobalClusterIdentifier}-Snapshot-KeyArn${Env}}}"}},"Script":"def script_handler(event, context):\n  import boto3, json, os,botocore\n  # Input parameters are provided by SSM document    \n  # DBSnapshotIdentifier = event.get(\"DBSnapshotIdentifier\")\n  SourceDBsnapshotArn = event.get(\"SourceDBsnapshotArn\")\n\n  DBSnapshotIdentifier = str(SourceDBsnapshotArn).split(\":\")[-1]\n  \n  sourceregion = event.get(\"sourceregion\")\n  targetregion = event.get(\"targetregion\")\n  kmstargetkey = event.get(\"kmstargetkey\")\n  \n  print(DBSnapshotIdentifier)\n  print(SourceDBsnapshotArn)                  \n  print(kmstargetkey)\n\n  # Define Target region in the region_name.Following API\n  # is expected to run in Target region. Hence, by setting region_name\n  # to Target region, we achive that.\n  client = boto3.client('rds', region_name=targetregion)\n  try: \n    response = client.copy_db_cluster_snapshot(\n        SourceDBClusterSnapshotIdentifier=SourceDBsnapshotArn,\n        TargetDBClusterSnapshotIdentifier=DBSnapshotIdentifier,\n        KmsKeyId=kmstargetkey, # KMS Key ID in Target region\n        CopyTags=False,\n        Tags=[\n                {\n                    'Key': 'NamingPrefix',\n                    'Value': 'catalog'\n                },\n            ],\n        SourceRegion=sourceregion # This attribute will automatically generate presigned URL\n    )\n    print(response)\n    copystatus = response.get(\"DBClusterSnapshot\").get(\"Status\")\n    print(\"Status of Copying of Snapshot:\" + str(copystatus))\n\n  except botocore.exceptions.ClientError as error:\n    raise error\n  except botocore.exceptions.ParamValidationError as error:\n    raise ValueError('The parameters you provided are incorrect: {}'.format(error))    "}}]},"documentType":"Automation","name":{"Fn::Join":["-",["CRDR-SSMAutomation-Catalog",{"Ref":"SourceRegion"},{"Fn::Select":[0,{"Fn::Split":["-",{"Fn::Select":[2,{"Fn::Split":["/",{"Ref":"AWS::StackId"}]}]}]}]}]]}}}},"$Hooks":{"id":"$Hooks","path":"ASHCDKNagScanner/deployment--database--crdr-reconciliation--src--cross-region-catalog-db-ssm.yaml/$Hooks","constructInfo":{"fqn":"constructs.Construct","version":"10.5.1"}},"$Outputs":{"id":"$Outputs","path":"ASHCDKNagScanner/deployment--database--crdr-reconciliation--src--cross-region-catalog-db-ssm.yaml/$Outputs","constructInfo":{"fqn":"constructs.Construct","version":"10.5.1"},"children":{"AutomationDocument":{"id":"AutomationDocument","path":"ASHCDKNagScanner/deployment--database--crdr-reconciliation--src--cross-region-catalog-db-ssm.yaml/$Outputs/AutomationDocument","constructInfo":{"fqn":"aws-cdk-lib.CfnOutput","version":"2.240.0"}}}}}},"BootstrapVersion":{"id":"BootstrapVersion","path":"ASHCDKNagScanner/BootstrapVersion","constructInfo":{"fqn":"aws-cdk-lib.CfnParameter","version":"2.240.0"}},"CheckBootstrapVersion":{"id":"CheckBootstrapVersion","path":"ASHCDKNagScanner/CheckBootstrapVersion","constructInfo":{"fqn":"aws-cdk-lib.CfnRule","version":"2.240.0"}}}},"Tree":{"id":"Tree","path":"Tree","constructInfo":{"fqn":"constructs.Construct","version":"10.5.1"}}}}}
{"$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/main/sarif-2.1/schema/sarif-schema-2.1.0.json", "version": "2.1.0", "runs": [{"tool": {"driver": {"name": "Checkov", "version": "3.2.506", "informationUri": "https://checkov.io", "rules": [{"id": "CKV_AWS_51", "name": "Ensure ECR Image Tags are immutable", "shortDescription": {"text": "Ensure ECR Image Tags are immutable"}, "fullDescription": {"text": "Ensure ECR Image Tags are immutable"}, "help": {"text": "Ensure ECR Image Tags are immutable\nResource: AWS::ECR::Repository.CheckoutRepo"}, "defaultConfiguration": {"level": "error"}, "helpUri": "https://docs.prismacloud.io/en/enterprise-edition/policy-reference/aws-policies/aws-general-policies/bc-aws-general-24"}, {"id": "CKV_AWS_23", "name": "Ensure every security groups rule has a description", "shortDescription": {"text": "Ensure every security groups rule has a description"}, "fullDescription": {"text": "Ensure every security groups rule has a description"}, "help": {"text": "Ensure every security groups rule has a description\nResource: AWS::EC2::SecurityGroupIngress.VPCEndpointSecurityGroupIngress"}, "defaultConfiguration": {"level": "error"}, "helpUri": "https://docs.prismacloud.io/en/enterprise-edition/policy-reference/aws-policies/aws-networking-policies/networking-31"}, {"id": "CKV_AWS_91", "name": "Ensure the ELBv2 (Application/Network) has access logging enabled", "shortDescription": {"text": "Ensure the ELBv2 (Application/Network) has access logging enabled"}, "fullDescription": {"text": "Ensure the ELBv2 (Application/Network) has access logging enabled"}, "help": {"text": "Ensure the ELBv2 (Application/Network) has access logging enabled\nResource: AWS::ElasticLoadBalancingV2::LoadBalancer.Alb"}, "defaultConfiguration": {"level": "error"}, "helpUri": "https://docs.prismacloud.io/en/enterprise-edition/policy-reference/aws-policies/aws-logging-policies/bc-aws-logging-22"}, {"id": "CKV_AWS_103", "name": "Ensure that Load Balancer Listener is using at least TLS v1.2", "shortDescription": {"text": "Ensure that Load Balancer Listener is using at least TLS v1.2"}, "fullDescription": {"text": "Ensure that Load Balancer Listener is using at least TLS v1.2"}, "help": {"text": "Ensure that Load Balancer Listener is using at least TLS v1.2\nResource: AWS::ElasticLoadBalancingV2::Listener.AlbListener"}, "defaultConfiguration": {"level": "error"}, "helpUri": "https://docs.prismacloud.io/en/enterprise-edition/policy-reference/aws-policies/aws-general-policies/bc-aws-general-43"}, {"id": "CKV_AWS_2", "name": "Ensure ALB protocol is HTTPS", "shortDescription": {"text": "Ensure ALB protocol is HTTPS"}, "fullDescription": {"text": "Ensure ALB protocol is HTTPS"}, "help": {"text": "Ensure ALB protocol is HTTPS\nResource: AWS::ElasticLoadBalancingV2::Listener.AlbListener"}, "defaultConfiguration": {"level": "error"}, "helpUri": "https://docs.prismacloud.io/en/enterprise-edition/policy-reference/aws-policies/aws-networking-policies/networking-29"}, {"id": "CKV_AWS_18", "name": "Ensure the S3 bucket has access logging enabled", "shortDescription": {"text": "Ensure the S3 bucket has access logging enabled"}, "fullDescription": {"text": "Ensure the S3 bucket has access logging enabled"}, "help": {"text": "Ensure the S3 bucket has access logging enabled\nResource: AWS::S3::Bucket.canaryBucket"}, "defaultConfiguration": {"level": "error"}, "helpUri": "https://docs.prismacloud.io/en/enterprise-edition/policy-reference/aws-policies/s3-policies/s3-13-enable-logging"}, {"id": "CKV_AWS_21", "name": "Ensure the S3 bucket has versioning enabled", "shortDescription": {"text": "Ensure the S3 bucket has versioning enabled"}, "fullDescription": {"text": "Ensure the S3 bucket has versioning enabled"}, "help": {"text": "Ensure the S3 bucket has versioning enabled\nResource: AWS::S3::Bucket.canaryBucket"}, "defaultConfiguration": {"level": "error"}, "helpUri": "https://docs.prismacloud.io/en/enterprise-edition/policy-reference/aws-policies/s3-policies/s3-16-enable-versioning"}, {"id": "CKV_AWS_111", "name": "Ensure IAM policies does not allow write access without constraints", "shortDescription": {"text": "Ensure IAM policies does not allow write access without constraints"}, "fullDescription": {"text": "Ensure IAM policies does not allow write access without constraints"}, "help": {"text": "Ensure IAM policies does not allow write access without constraints\nResource: AWS::IAM::Role.RegionSwitchExecutionRole"}, "defaultConfiguration": {"level": "error"}, "helpUri": "https://docs.prismacloud.io/en/enterprise-edition/policy-reference/aws-policies/aws-iam-policies/ensure-iam-policies-do-not-allow-write-access-without-constraint"}, {"id": "CKV_AWS_116", "name": "Ensure that AWS Lambda function is configured for a Dead Letter Queue(DLQ)", "shortDescription": {"text": "Ensure that AWS Lambda function is configured for a Dead Letter Queue(DLQ)"}, "fullDescription": {"text": "Ensure that AWS Lambda function is configured for a Dead Letter Queue(DLQ)"}, "help": {"text": "Ensure that AWS Lambda function is configured for a Dead Letter Queue(DLQ)\nResource: AWS::Serverless::Function.LambdaFunction"}, "defaultConfiguration": {"level": "error"}, "helpUri": "https://docs.prismacloud.io/en/enterprise-edition/policy-reference/aws-policies/aws-general-policies/ensure-that-aws-lambda-function-is-configured-for-a-dead-letter-queue-dlq"}, {"id": "CKV_AWS_173", "name": "Check encryption settings for Lambda environment variable", "shortDescription": {"text": "Check encryption settings for Lambda environment variable"}, "fullDescription": {"text": "Check encryption settings for Lambda environment variable"}, "help": {"text": "Check encryption settings for Lambda environment variable\nResource: AWS::Serverless::Function.LambdaFunction"}, "defaultConfiguration": {"level": "error"}, "helpUri": "https://docs.prismacloud.io/en/enterprise-edition/policy-reference/aws-policies/aws-serverless-policies/bc-aws-serverless-5"}, {"id": "CKV_AWS_364", "name": "Ensure that AWS Lambda function permissions delegated to AWS services are limited by SourceArn or SourceAccount", "shortDescription": {"text": "Ensure that AWS Lambda function permissions delegated to AWS services are limited by SourceArn or SourceAccount"}, "fullDescription": {"text": "Ensure that AWS Lambda function permissions delegated to AWS services are limited by SourceArn or SourceAccount"}, "help": {"text": "Ensure that AWS Lambda function permissions delegated to AWS services are limited by SourceArn or SourceAccount\nResource: AWS::Lambda::Permission.LambdaInvokePermission"}, "defaultConfiguration": {"level": "error"}, "helpUri": "https://docs.prismacloud.io/en/enterprise-edition/policy-reference/aws-policies/aws-iam-policies/bc-aws-364"}, {"id": "CKV_AWS_117", "name": "Ensure that AWS Lambda function is configured inside a VPC", "shortDescription": {"text": "Ensure that AWS Lambda function is configured inside a VPC"}, "fullDescription": {"text": "Ensure that AWS Lambda function is configured inside a VPC"}, "help": {"text": "Ensure that AWS Lambda function is configured inside a VPC\nResource: AWS::Lambda::Function.CustomBackedLambda"}, "defaultConfiguration": {"level": "error"}, "helpUri": "https://docs.prismacloud.io/en/enterprise-edition/policy-reference/aws-policies/aws-general-policies/ensure-that-aws-lambda-function-is-configured-inside-a-vpc-1"}, {"id": "CKV_AWS_115", "name": "Ensure that AWS Lambda function is configured for function-level concurrent execution limit", "shortDescription": {"text": "Ensure that AWS Lambda function is configured for function-level concurrent execution limit"}, "fullDescription": {"text": "Ensure that AWS Lambda function is configured for function-level concurrent execution limit"}, "help": {"text": "Ensure that AWS Lambda function is configured for function-level concurrent execution limit\nResource: AWS::Lambda::Function.CustomBackedLambda"}, "defaultConfiguration": {"level": "error"}, "helpUri": "https://docs.prismacloud.io/en/enterprise-edition/policy-reference/aws-policies/aws-general-policies/ensure-that-aws-lambda-function-is-configured-for-function-level-concurrent-execution-limit"}, {"id": "CKV_OPENAPI_5", "name": "Ensure that security operations is not empty.", "shortDescription": {"text": "Ensure that security operations is not empty."}, "fullDescription": {"text": "Ensure that security operations is not empty."}, "help": {"text": "Ensure that security operations is not empty.\nResource: security"}, "defaultConfiguration": {"level": "error"}, "helpUri": "https://docs.prismacloud.io/en/enterprise-edition/policy-reference/api-policies/openapi-policies/ensure-that-security-operations-is-not-empty"}, {"id": "CKV_OPENAPI_4", "name": "Ensure that the global security field has rules defined", "shortDescription": {"text": "Ensure that the global security field has rules defined"}, "fullDescription": {"text": "Ensure that the global security field has rules defined"}, "help": {"text": "Ensure that the global security field has rules defined\nResource: security"}, "defaultConfiguration": {"level": "error"}, "helpUri": "https://docs.prismacloud.io/en/enterprise-edition/policy-reference/api-policies/openapi-policies/ensure-that-the-global-security-field-has-rules-defined"}, {"id": "CKV_OPENAPI_21", "name": "Ensure that arrays have a maximum number of items", "shortDescription": {"text": "Ensure that arrays have a maximum number of items"}, "fullDescription": {"text": "Ensure that arrays have a maximum number of items"}, "help": {"text": "Ensure that arrays have a maximum number of items\nResource: paths"}, "defaultConfiguration": {"level": "error"}, "helpUri": "https://docs.prismacloud.io/en/enterprise-edition/policy-reference/api-policies/openapi-policies/bc-openapi-21"}], "organization": "bridgecrew"}}, "results": [{"ruleId": "CKV_AWS_51", "ruleIndex": 0, "level": "error", "attachments": [], "message": {"text": "Ensure ECR Image Tags are immutable"}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "deployment/regionalBaseInfra.yaml"}, "region": {"startLine": 266, "endLine": 275, "snippet": {"text": "  CheckoutRepo:\n    Type: AWS::ECR::Repository\n    Properties:\n      ImageScanningConfiguration:\n        ScanOnPush: true\n      RepositoryName: !Sub 'checkout${Env}'\n      ImageTagMutability: MUTABLE\n      EncryptionConfiguration:\n        EncryptionType: KMS\n        KmsKey: !Ref KmsKey\n"}}}}]}, {"ruleId": "CKV_AWS_51", "ruleIndex": 0, "level": "error", "attachments": [], "message": {"text": "Ensure ECR Image Tags are immutable"}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "deployment/regionalBaseInfra.yaml"}, "region": {"startLine": 276, "endLine": 285, "snippet": {"text": "  CatalogRepo:\n    Type: AWS::ECR::Repository\n    Properties:\n      ImageScanningConfiguration:\n          ScanOnPush: true\n      RepositoryName: !Sub 'catalog${Env}'\n      ImageTagMutability: MUTABLE\n      EncryptionConfiguration:\n        EncryptionType: KMS\n        KmsKey: !Ref KmsKey\n"}}}}]}, {"ruleId": "CKV_AWS_51", "ruleIndex": 0, "level": "error", "attachments": [], "message": {"text": "Ensure ECR Image Tags are immutable"}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "deployment/regionalBaseInfra.yaml"}, "region": {"startLine": 286, "endLine": 295, "snippet": {"text": "  CartsRepo:\n    Type: AWS::ECR::Repository\n    Properties:\n      ImageScanningConfiguration:\n        ScanOnPush: true\n      RepositoryName: !Sub 'carts${Env}'\n      ImageTagMutability: MUTABLE\n      EncryptionConfiguration:\n        EncryptionType: KMS\n        KmsKey: !Ref KmsKey\n"}}}}]}, {"ruleId": "CKV_AWS_51", "ruleIndex": 0, "level": "error", "attachments": [], "message": {"text": "Ensure ECR Image Tags are immutable"}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "deployment/regionalBaseInfra.yaml"}, "region": {"startLine": 296, "endLine": 305, "snippet": {"text": "  AssetsRepo:\n    Type: AWS::ECR::Repository\n    Properties:\n      ImageScanningConfiguration:\n        ScanOnPush: true\n      RepositoryName: !Sub 'assets${Env}'\n      ImageTagMutability: MUTABLE\n      EncryptionConfiguration:\n        EncryptionType: KMS\n        KmsKey: !Ref KmsKey\n"}}}}]}, {"ruleId": "CKV_AWS_51", "ruleIndex": 0, "level": "error", "attachments": [], "message": {"text": "Ensure ECR Image Tags are immutable"}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "deployment/regionalBaseInfra.yaml"}, "region": {"startLine": 306, "endLine": 315, "snippet": {"text": "  OrdersRepo:\n    Type: AWS::ECR::Repository\n    Properties:\n      ImageScanningConfiguration:\n        ScanOnPush: true\n      RepositoryName: !Sub 'orders${Env}'\n      ImageTagMutability: MUTABLE\n      EncryptionConfiguration:\n        EncryptionType: KMS\n        KmsKey: !Ref KmsKey\n"}}}}]}, {"ruleId": "CKV_AWS_51", "ruleIndex": 0, "level": "error", "attachments": [], "message": {"text": "Ensure ECR Image Tags are immutable"}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "deployment/regionalBaseInfra.yaml"}, "region": {"startLine": 316, "endLine": 325, "snippet": {"text": "  UIRepo:\n    Type: AWS::ECR::Repository\n    Properties:\n      ImageScanningConfiguration:\n        ScanOnPush: true\n      RepositoryName: !Sub 'ui${Env}'\n      ImageTagMutability: MUTABLE\n      EncryptionConfiguration:\n        EncryptionType: KMS\n        KmsKey: !Ref KmsKey\n"}}}}]}, {"ruleId": "CKV_AWS_23", "ruleIndex": 1, "level": "error", "attachments": [], "message": {"text": "Ensure every security groups rule has a description"}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "deployment/ecs.yaml"}, "region": {"startLine": 136, "endLine": 143, "snippet": {"text": "  VPCEndpointSecurityGroupIngress:\n    Type: AWS::EC2::SecurityGroupIngress\n    Properties:\n      GroupId: !Sub '{{resolve:ssm:VPCEndpointSecretsManagerSGId${Env}}}'\n      IpProtocol: tcp\n      FromPort: 443\n      ToPort: 443\n      SourceSecurityGroupId: !Ref sgTask\n"}}}}]}, {"ruleId": "CKV_AWS_23", "ruleIndex": 1, "level": "error", "attachments": [], "message": {"text": "Ensure every security groups rule has a description"}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "deployment/ecs.yaml"}, "region": {"startLine": 144, "endLine": 151, "snippet": {"text": "  VPCEndpointSSMSecurityGroupIngress:\n    Type: AWS::EC2::SecurityGroupIngress\n    Properties:\n      GroupId: !Sub '{{resolve:ssm:VPCEndpointSSMSGId${Env}}}'\n      IpProtocol: tcp\n      FromPort: 443\n      ToPort: 443\n      SourceSecurityGroupId: !Ref sgTask\n"}}}}]}, {"ruleId": "CKV_AWS_91", "ruleIndex": 2, "level": "error", "attachments": [], "message": {"text": "Ensure the ELBv2 (Application/Network) has access logging enabled"}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "deployment/ecs.yaml"}, "region": {"startLine": 306, "endLine": 319, "snippet": {"text": "  Alb:\n    Type: AWS::ElasticLoadBalancingV2::LoadBalancer\n    Properties:\n      Scheme: internal\n      LoadBalancerAttributes:\n        - Key: routing.http.drop_invalid_header_fields.enabled\n          Value: true\n      SecurityGroups: \n        - !Ref sgAlb\n      Subnets:\n        - !Sub '{{resolve:ssm:Subnet1${Env}}}'\n        - !Sub '{{resolve:ssm:Subnet2${Env}}}'\n        - !Sub '{{resolve:ssm:Subnet3${Env}}}'\n      Type: application\n"}}}}]}, {"ruleId": "CKV_AWS_103", "ruleIndex": 3, "level": "error", "attachments": [], "message": {"text": "Ensure that Load Balancer Listener is using at least TLS v1.2"}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "deployment/ecs.yaml"}, "region": {"startLine": 341, "endLine": 349, "snippet": {"text": "  AlbListener:\n    Type: AWS::ElasticLoadBalancingV2::Listener\n    Properties: \n      DefaultActions: \n        - Type: forward\n          TargetGroupArn: !Ref AlbTargetGroup\n      LoadBalancerArn: !Ref Alb\n      Port: 80\n      Protocol: HTTP\n"}}}}]}, {"ruleId": "CKV_AWS_2", "ruleIndex": 4, "level": "error", "attachments": [], "message": {"text": "Ensure ALB protocol is HTTPS"}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "deployment/ecs.yaml"}, "region": {"startLine": 341, "endLine": 349, "snippet": {"text": "  AlbListener:\n    Type: AWS::ElasticLoadBalancingV2::Listener\n    Properties: \n      DefaultActions: \n        - Type: forward\n          TargetGroupArn: !Ref AlbTargetGroup\n      LoadBalancerArn: !Ref Alb\n      Port: 80\n      Protocol: HTTP\n"}}}}]}, {"ruleId": "CKV_AWS_18", "ruleIndex": 5, "level": "error", "attachments": [], "message": {"text": "Ensure the S3 bucket has access logging enabled"}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "deployment/regionalVpc.yaml"}, "region": {"startLine": 164, "endLine": 176, "snippet": {"text": "  canaryBucket:\n    Type: AWS::S3::Bucket\n    Properties:\n      PublicAccessBlockConfiguration:\n        BlockPublicAcls: true\n        BlockPublicPolicy: true\n        IgnorePublicAcls: true\n        RestrictPublicBuckets: true\n      LifecycleConfiguration:\n        Rules:\n          - Id: DeleteAfter24Hours\n            Status: Enabled\n            ExpirationInDays: 1\n"}}}}]}, {"ruleId": "CKV_AWS_21", "ruleIndex": 6, "level": "error", "attachments": [], "message": {"text": "Ensure the S3 bucket has versioning enabled"}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "deployment/regionalVpc.yaml"}, "region": {"startLine": 164, "endLine": 176, "snippet": {"text": "  canaryBucket:\n    Type: AWS::S3::Bucket\n    Properties:\n      PublicAccessBlockConfiguration:\n        BlockPublicAcls: true\n        BlockPublicPolicy: true\n        IgnorePublicAcls: true\n        RestrictPublicBuckets: true\n      LifecycleConfiguration:\n        Rules:\n          - Id: DeleteAfter24Hours\n            Status: Enabled\n            ExpirationInDays: 1\n"}}}}]}, {"ruleId": "CKV_AWS_23", "ruleIndex": 1, "level": "error", "attachments": [], "message": {"text": "Ensure every security groups rule has a description"}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "deployment/windows.yaml"}, "region": {"startLine": 76, "endLine": 94, "snippet": {"text": "  SecurityGroup:\n    Type: AWS::EC2::SecurityGroup\n    Properties:\n      VpcId: !Ref 'VpcId'\n      GroupDescription: OutboundOnly\n      SecurityGroupIngress:\n        - IpProtocol: tcp\n          FromPort: 3389\n          ToPort: 3389\n          CidrIp: 10.1.0.0/16\n      SecurityGroupEgress:\n        - IpProtocol: tcp\n          FromPort: 443\n          ToPort: 443\n          CidrIp: 0.0.0.0/0\n        - IpProtocol: tcp\n          FromPort: 80\n          ToPort: 80\n          CidrIp: 0.0.0.0/0\n"}}}}]}, {"ruleId": "CKV_AWS_23", "ruleIndex": 1, "level": "error", "attachments": [], "message": {"text": "Ensure every security groups rule has a description"}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "deployment/windows.yaml"}, "region": {"startLine": 95, "endLine": 102, "snippet": {"text": "  VPCEndpointSSMSecurityGroupIngress:\n    Type: AWS::EC2::SecurityGroupIngress\n    Properties:\n      GroupId: !Sub '{{resolve:ssm:VPCEndpointSSMSGId${Env}}}'\n      IpProtocol: tcp\n      FromPort: 443\n      ToPort: 443\n      SourceSecurityGroupId: !Ref SecurityGroup\n"}}}}]}, {"ruleId": "CKV_AWS_23", "ruleIndex": 1, "level": "error", "attachments": [], "message": {"text": "Ensure every security groups rule has a description"}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "deployment/windows.yaml"}, "region": {"startLine": 103, "endLine": 110, "snippet": {"text": "  VPCEndpointSecretsManagerSecurityGroupIngress:\n    Type: AWS::EC2::SecurityGroupIngress\n    Properties:\n      GroupId: !Sub '{{resolve:ssm:VPCEndpointSecretsManagerSGId${Env}}}'\n      IpProtocol: tcp\n      FromPort: 443\n      ToPort: 443\n      SourceSecurityGroupId: !Ref SecurityGroup"}}}}]}, {"ruleId": "CKV_AWS_111", "ruleIndex": 7, "level": "error", "attachments": [], "message": {"text": "Ensure IAM policies does not allow write access without constraints"}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "deployment/failover.yaml"}, "region": {"startLine": 29, "endLine": 113, "snippet": {"text": "  RegionSwitchExecutionRole:\n    Type: AWS::IAM::Role\n    Properties:\n      RoleName: !Sub 'RegionSwitchExecutionRole${Env}'\n      AssumeRolePolicyDocument:\n        Version: '2012-10-17'\n        Statement:\n          - Effect: Allow\n            Principal:\n              Service: arc-region-switch.amazonaws.com\n            Action: sts:AssumeRole\n      Policies:\n        - PolicyName: RegionSwitchPolicy\n          PolicyDocument:\n            Version: '2012-10-17'\n            Statement:\n              - Effect: Allow\n                Action:\n                  - \"arc-region-switch:GetPlan\"\n                  - \"arc-region-switch:GetPlanExecution\"\n                  - \"arc-region-switch:ListPlanExecutions\"\n                Resource: \"*\"\n              - Effect: Allow\n                Action:\n                  - \"iam:SimulatePrincipalPolicy\"\n                Resource: !Sub 'arn:aws:iam::${AWS::AccountId}:role/RegionSwitchExecutionRole${Env}'\n              - Effect: Allow\n                Action:\n                  - \"cloudwatch:DescribeAlarms\"\n                  - \"cloudwatch:DescribeAlarmHistory\"\n                  - \"cloudwatch:GetMetricStatistics\"\n                Resource: \"*\"\n              - Effect: Allow\n                Action:\n                  - \"ecs:DescribeServices\"\n                  - \"ecs:UpdateService\"\n                Resource:\n                  - !Sub\n                    - 'arn:aws:ecs:${PrimaryRegion}:${AWS::AccountId}:service/${ClusterName}/*'\n                    - ClusterName: !Select [1, !Split [\"/\", !Ref PrimaryClusterArn]]\n                  - !Sub\n                    - 'arn:aws:ecs:${StandbyRegion}:${AWS::AccountId}:service/${ClusterName}/*'\n                    - ClusterName: !Select [1, !Split [\"/\", !Ref StandbyClusterArn]]\n              - Effect: Allow\n                Action:\n                  - \"ecs:DescribeClusters\"\n                Resource:\n                  - !Ref PrimaryClusterArn\n                  - !Ref StandbyClusterArn\n              - Effect: Allow\n                Action:\n                  - \"ecs:ListServices\"\n                Resource: \"*\"\n              - Effect: Allow\n                Action:\n                  - \"application-autoscaling:DescribeScalableTargets\"\n                  - \"application-autoscaling:RegisterScalableTarget\"\n                Resource: \"*\"\n              - Effect: Allow\n                Action:\n                  - \"rds:DescribeGlobalClusters\"\n                  - \"rds:DescribeDBClusters\"\n                Resource: \"*\"\n              - Effect: Allow\n                Action:\n                  - \"rds:FailoverGlobalCluster\"\n                  - \"rds:SwitchoverGlobalCluster\"\n                Resource:\n                  - !Sub 'arn:aws:rds::${AWS::AccountId}:global-cluster:catalog-global-db-cluster${Env}'\n                  - !Sub '{{resolve:secretsmanager:mr-app/catalog-${PrimaryRegion}-global-db-cluster${Env}}}'\n                  - !Sub '{{resolve:secretsmanager:mr-app/catalog-${StandbyRegion}-global-db-cluster${Env}}}'\n              - Effect: Allow\n                Action:\n                  - \"route53:ChangeResourceRecordSets\"\n                  - \"route53:GetHostedZone\"\n                  - \"route53:ListResourceRecordSets\"\n                Resource:\n                  - !Sub\n                    - 'arn:aws:route53:::hostedzone/${HostedZoneId}'\n                    - HostedZoneId: !Sub '{{resolve:secretsmanager:HostedZoneIdSecret${Env}}}'\n              - Effect: Allow\n                Action:\n                  - \"route53:GetHealthCheck\"\n                  - \"route53:UpdateHealthCheck\"\n                Resource: \"arn:aws:route53:::healthcheck/*\"\n"}}}}]}, {"ruleId": "CKV_AWS_23", "ruleIndex": 1, "level": "error", "attachments": [], "message": {"text": "Ensure every security groups rule has a description"}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "deployment/database/crdr-reconciliation/src/restore-reconcile-catalog-ssm.yaml"}, "region": {"startLine": 67, "endLine": 74, "snippet": {"text": "  VPCEndpointSecurityGroupIngress:\n    Type: AWS::EC2::SecurityGroupIngress\n    Properties:\n      GroupId: !Sub '{{resolve:ssm:VPCEndpointSecretsManagerSGId${Env}}}'\n      IpProtocol: tcp\n      FromPort: 443\n      ToPort: 443\n      SourceSecurityGroupId: !Ref LambdaSecurityGroup\n"}}}}]}, {"ruleId": "CKV_AWS_116", "ruleIndex": 8, "level": "error", "attachments": [], "message": {"text": "Ensure that AWS Lambda function is configured for a Dead Letter Queue(DLQ)"}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "deployment/database/crdr-reconciliation/src/restore-reconcile-catalog-ssm.yaml"}, "region": {"startLine": 99, "endLine": 155, "snippet": {"text": "  LambdaFunction:\n    Type: AWS::Serverless::Function\n    Properties:\n      Handler: reconciliation-catalog.lambda_handler\n      CodeUri: function/.\n      Runtime: python3.12\n      Architectures:\n        - x86_64\n      EphemeralStorage:\n        Size: 512\n      Timeout: 600\n      ReservedConcurrentExecutions: 5\n      PackageType: Zip\n      VpcConfig:\n        SecurityGroupIds:\n          - !Ref LambdaSecurityGroup          \n        SubnetIds:\n          - !Sub '{{resolve:ssm:Subnet1${Env}}}'\n          - !Sub '{{resolve:ssm:Subnet2${Env}}}'\n          - !Sub '{{resolve:ssm:Subnet3${Env}}}'        \n        Ipv6AllowedForDualStack: false\n      Environment:\n        Variables:\n          DB_CREDENTIALS_SECRET_ID: !Sub 'mr-app/catalog-${GlobalClusterIdentifier}-UserCredentials${Env}'\n      Layers:\n       